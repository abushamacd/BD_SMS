# ---------------------------------------------------------------------------
# BD SMS — copy to .env and fill in.
# SHOPIFY_API_KEY / SHOPIFY_API_SECRET are injected by the Shopify CLI.
# ---------------------------------------------------------------------------

# Database. Local: XAMPP MySQL. Production: managed MySQL.
DATABASE_URL="mysql://root@127.0.0.1:3306/bd_sms"

# AES-256-GCM key for encrypting merchant gateway credentials at rest.
# Generate with: openssl rand -hex 32
# Must be unique per environment. Changing it orphans all stored credentials.
ENCRYPTION_KEY=""

# Default gateway (our account — used by merchants who buy credits from us).
DEFAULT_SMS_PROVIDER="bulksmsbd"
# HTTPS, not the http:// URL in BulkSMSBD's docs — phone numbers must be
# encrypted in transit (Shopify protected customer data requirement).
DEFAULT_SMS_API_URL="https://bulksmsbd.net/api/smsapi"
DEFAULT_SMS_API_KEY=""
DEFAULT_SMS_SENDER_ID=""

# When true, messages are logged but never sent to the gateway.
SMS_DRY_RUN="true"
